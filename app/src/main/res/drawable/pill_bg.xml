<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Background color -->
    <solid android:color="#FFFFFF"/>

    <!-- Rounded pill shape -->
    <corners android:radius="50dp"/>

    <!-- Optional border -->
    <stroke
        android:width="1dp"
        android:color="#D0DCE8"/>

    <!-- Padding inside -->
    <padding
        android:left="12dp"
        android:right="12dp"
        android:top="6dp"
        android:bottom="6dp"/>

</shape>