<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- 🌿 Soft Mint Gradient -->
    <gradient
        android:type="linear"
        android:startColor="#80E9D4"
        android:endColor="#5EDCC3"
        android:angle="45" />

    <!-- 🌟 Rounded Corners -->
    <corners android:radius="40dp" />

    <!-- 💫 Soft White Glow Border -->
    <stroke
        android:width="2dp"
        android:color="#80FFFFFF" />

    <padding
        android:left="10dp"
        android:right="10dp"
        android:top="6dp"
        android:bottom="6dp" />
</shape>
