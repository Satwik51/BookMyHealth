<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="oval">

    <!-- 🔹 Background color (Blue tone) -->
    <solid android:color="#0D99FF" />

    <!-- 🔹 Optional white border -->
    <stroke
        android:width="2dp"
        android:color="#FFFFFF" />

    <!-- 🔹 Optional padding (if you use icons inside) -->
    <padding
        android:left="8dp"
        android:top="8dp"
        android:right="8dp"
        android:bottom="8dp" />

    <!-- 🔹 Subtle shadow (API 21+) -->
    <size
        android:width="100dp"
        android:height="100dp" />

</shape>
