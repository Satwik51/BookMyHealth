<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Base.Theme.BookMyHealth" parent="Theme.Material3.DayNight.NoActionBar">

        <!-- Brand -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryContainer">@color/colorPrimaryContainer</item>
        <item name="colorOnPrimaryContainer">@color/textPrimary</item>

        <!-- Secondary -->
        <item name="colorSecondary">@color/highlightYellow</item>
        <item name="colorOnSecondary">@color/black</item>

        <!-- Surface & Background -->
        <item name="colorSurface">@color/colorSurface</item>
        <item name="colorOnSurface">@color/textPrimary</item>
        <item name="colorOnSurfaceVariant">@color/textSecondary</item>
        <item name="android:colorBackground">@color/colorBackground</item>

        <!-- Text on primary -->
        <item name="colorOnPrimary">@color/white</item>

        <!-- System bars — transparent for edge-to-edge -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar" tools:targetApi="23">true</item>

    </style>

    <style name="Theme.BookMyHealth" parent="Base.Theme.BookMyHealth"/>

</resources>