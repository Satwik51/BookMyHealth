<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_modern_texture"
    android:fitsSystemWindows="true">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:padding="18dp"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">


            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Book Appointment"
                android:textSize="30dp"
                android:textStyle="bold"
                android:textColor="@color/primary_blue"
                android:layout_marginTop="14dp" />

            <!-- ⭐ DOCTOR MAIN CARD -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="22dp"
                app:cardElevation="14dp"
                android:layout_marginTop="20dp"
                app:strokeWidth="1dp"
                app:strokeColor="#DADADA"
                app:cardBackgroundColor="@color/main">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp"
                    android:background="@drawable/bg_app"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/ivDoctorPhoto"
                        android:layout_width="95dp"
                        android:layout_height="95dp"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_doctor_placeholder"
                        app:shapeAppearanceOverlay="@style/RoundedImage"
                        app:strokeColor="@color/white"
                        app:strokeWidth="2dp"
                        />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvDoctorName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Dr. Sarah Johnson"
                            android:textSize="21sp"
                            android:textColor="@color/white"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvSpecialization"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Cardiologist"
                            android:textSize="15sp"
                            android:textColor="#FFFFFF"
                            android:layout_marginTop="4dp" />

                        <TextView
                            android:id="@+id/tvExperience"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="10+ years experience"
                            android:textSize="13sp"
                            android:textColor="#FFFFFF"
                            android:layout_marginTop="4dp" />

                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ⭐ ABOUT DOCTOR -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="About Doctor"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/primary_blue"
                android:layout_marginTop="14dp" />

            <TextView
                android:id="@+id/tvAboutDoctor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Loading..."
                android:background="@drawable/bg_info_card"
                android:layout_marginTop="6dp"
                android:textSize="15sp"
                android:textColor="#444444" />

            <!-- ⭐ CLINIC INFORMATION -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Clinic Information"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/primary_blue"
                android:layout_marginTop="20dp" />

            <TextView
                android:id="@+id/tvClinicInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Loading..."
                android:layout_marginTop="6dp"
                android:textSize="15sp"
                android:background="@drawable/bg_info_card"
                android:textColor="#444444" />

            <!-- ⭐ WEEK AVAILABILITY -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Weekly Availability"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/primary_blue"
                android:layout_marginTop="20dp" />

            <LinearLayout
                android:id="@+id/layoutWeekAvailability"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="6dp"
                android:padding="10dp"
                android:background="@drawable/bg_info_card"
                />

            <!-- ⭐ AVAILABLE SLOTS -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Available Slots"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/primary_blue"
                android:layout_marginTop="20dp" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipSlots"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:chipSpacing="10dp"
                android:background="@drawable/bg_info_card"
                app:singleSelection="true"
                app:singleLine="false" />

            <!-- ⭐ AWARDS & ACHIEVEMENTS -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Awards &amp; Achievements"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/primary_blue"
                android:layout_marginTop="20dp" />

            <LinearLayout
                android:id="@+id/layoutAwards"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="6dp"
                android:background="@drawable/bg_info_card"
                android:paddingBottom="10dp"
                android:dividerPadding="10dp" />

            <!-- ⭐ DATE PICKER -->
            <TextView
                android:text="Select Date"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/primary_blue"
                android:layout_marginTop="26dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Select Date"
                app:startIconDrawable="@drawable/ic_calender"
                app:startIconTint="@color/primary_blue"
                android:layout_marginTop="8dp"
                app:boxBackgroundMode="filled"
                app:boxBackgroundColor="@android:color/white"
                app:boxCornerRadiusTopStart="16dp"
                app:boxCornerRadiusTopEnd="16dp"
                app:boxCornerRadiusBottomStart="16dp"
                app:boxCornerRadiusBottomEnd="16dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etDate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:focusable="false"
                    android:clickable="true"
                    android:textSize="16sp"
                    android:textColor="@color/black"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- ⭐ TIME PICKER -->
            <TextView
                android:text="Select Time"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/primary_blue"
                android:layout_marginTop="18dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Select Time"
                app:startIconDrawable="@drawable/ic_clock"
                app:startIconTint="@color/primary_blue"
                app:boxBackgroundMode="filled"
                android:layout_marginTop="8dp"
                app:boxBackgroundColor="@android:color/white"
                app:boxCornerRadiusTopStart="16dp"
                app:boxCornerRadiusTopEnd="16dp"
                app:boxCornerRadiusBottomStart="16dp"
                app:boxCornerRadiusBottomEnd="16dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etTime"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:focusable="false"
                    android:clickable="true"
                    android:textSize="16sp"
                    android:textColor="@color/black"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- ⭐ BOOK BUTTON -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBook"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:text="Book Appointment"
                android:textAllCaps="false"
                android:textSize="17sp"
                android:padding="14dp"
                android:textColor="@android:color/white"
                android:backgroundTint="@color/primary_blue"
                app:cornerRadius="18dp"
                android:layout_marginBottom="50dp"
                android:elevation="6dp"/>

        </LinearLayout>
    </ScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
