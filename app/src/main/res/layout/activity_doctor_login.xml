<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".ui.auth.doctor.DoctorLoginActivity">

    <!-- 🔹 Header Section -->
    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/bg_intro_curve"
        android:elevation="4dp">

        <!-- 🔹 Lottie Animation (Added) -->
        <com.airbnb.lottie.LottieAnimationView
            android:id="@+id/lottieAnimationView"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:layout_marginTop="30dp"
            android:layout_marginBottom="20dp"
            app:lottie_rawRes="@raw/login"
            app:lottie_autoPlay="true"
            app:lottie_loop="true"
            app:lottie_speed="2" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Doctor Login"
            android:textColor="#80E9D4"
            android:textStyle="bold"
            android:textSize="26sp"
            />
    </LinearLayout>

    <!-- 🔹 Scrollable Login Content -->
    <ScrollView
        android:id="@+id/scrollLogin"
        android:layout_below="@id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:padding="20dp"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_rounded"
            android:elevation="5dp"
            android:padding="24dp"
            android:layout_marginTop="10dp">

            <!-- Email Field -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="      Email Address"
                app:startIconDrawable="@drawable/ic_email"

                app:boxBackgroundMode="filled"
                app:boxCornerRadiusTopStart="16dp"
                app:boxCornerRadiusTopEnd="16dp"
                app:boxCornerRadiusBottomStart="16dp"
                app:boxCornerRadiusBottomEnd="16dp"
                app:boxBackgroundColor="@color/white">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etEmail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textEmailAddress"
                    android:textColor="#000"
                    android:padding="12dp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Password Field -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="      Password"
                app:startIconDrawable="@drawable/ic_lock"
                app:endIconMode="password_toggle"
                app:boxBackgroundMode="filled"
                app:boxCornerRadiusTopStart="16dp"
                app:boxCornerRadiusTopEnd="16dp"
                app:boxCornerRadiusBottomStart="16dp"
                app:boxCornerRadiusBottomEnd="16dp"
                app:boxBackgroundColor="@color/white"
                android:layout_marginTop="16dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword"
                    android:textColor="#000"
                    android:padding="12dp" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Login Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Login"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:textColor="@color/white"
                android:backgroundTint="@color/primary_blue"
                android:layout_marginTop="24dp"
                app:cornerRadius="12dp"
                android:elevation="2dp" />

            <!-- NEW: Divider for Social Sign-in -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="20dp">

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="#CCCCCC"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  OR  "
                    android:textColor="#666666"
                    android:textSize="14sp"/>

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="#CCCCCC"/>
            </LinearLayout>

            <!-- NEW: Google Sign-in Button -->
            <!-- ID: btnGoogleSignin, background: White, Text: Black, Icon: Google Logo -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGoogleDoctorSignin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Login with Google"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:textColor="#000000"
                android:backgroundTint="@color/white"
                app:cornerRadius="12dp"
                app:strokeColor="#CCCCCC"
                app:strokeWidth="1dp"
                android:paddingVertical="10dp"
                app:icon="@drawable/ic_google_logo"
                app:iconTint="@null"
                app:iconSize="24dp"
                app:iconGravity="textStart"
                app:iconPadding="10dp"
                android:elevation="2dp" />




            <!-- Sign Up Redirect -->
            <TextView
                android:id="@+id/tvSignup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Don’t have an account? Sign Up"
                android:textColor="#0D99FF"
                android:textSize="14sp"
                android:layout_marginTop="18dp"
                android:layout_gravity="center_horizontal" />
        </LinearLayout>
    </ScrollView>

    <!-- 🔹 Progress Overlay -->
    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyleLarge"
        android:layout_centerInParent="true"
        android:indeterminate="true"
        android:visibility="gone"
        android:progressTint="@color/primary_blue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />
    <TextView
        android:id="@+id/tvBackToRole"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="← Back to Role Selection"
        android:textColor="@color/black"
        android:textStyle="bold"
        android:textSize="15sp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="16dp"
        android:padding="8dp" />

</RelativeLayout>
