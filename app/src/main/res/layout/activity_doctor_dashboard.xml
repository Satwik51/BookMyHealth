<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/doctorDrawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.auth.doctor.DoctorDashboardActivity">

    <!-- MAIN SCREEN LAYOUT -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/white">

        <!-- 🌟 HEADER + SLIDER -->
        <LinearLayout
            android:id="@+id/doctorTopContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_intro_curve"
            android:paddingBottom="20dp">

            <!-- HEADER -->
            <LinearLayout
                android:id="@+id/headerDoctor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="18dp"
                android:paddingTop="32dp"
                android:paddingBottom="20dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/ivDoctorProfile"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:src="@drawable/placeholder_profile"
                    android:background="@drawable/bg_circle_white"
                    android:padding="6dp"
                    android:elevation="4dp"
                    android:scaleType="centerCrop" />

                <LinearLayout
                    android:orientation="vertical"
                    android:layout_marginStart="14dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/tvWelcome"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Welcome"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/white" />

                    <TextView
                        android:id="@+id/tvDoctorName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Dr. Loading..."
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#80E9D4" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvDoctorEmoji"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="👨‍⚕️"
                    android:layout_marginStart="8dp"
                    android:textSize="34sp" />
            </LinearLayout>

            <!-- LOTTIE SLIDER -->
            <androidx.viewpager2.widget.ViewPager2
                android:id="@+id/lottieSlider"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:layout_marginHorizontal="16dp"
                android:clipToPadding="false"
                android:clipChildren="false"
                android:paddingHorizontal="10dp"
                android:overScrollMode="never" />

        </LinearLayout>




        <!-- 🔍 SEARCH BAR -->
        <LinearLayout
            android:id="@+id/layoutSearchBarDoctor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="16dp"
            android:layout_marginTop="6dp">

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/SearchLayoutDoctor"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:background="@drawable/bg_search_curve"
                android:padding="0dp"
                android:layout_marginEnd="10dp"
                app:boxBackgroundMode="none"
                app:startIconDrawable="@drawable/ic_search"
                app:startIconTint="@color/black">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etSearchDoctor"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:textSize="18sp"
                    android:gravity="center_vertical"
                    android:hint="Search appointment..."
                    android:textColor="#000"
                    android:background="@android:color/transparent" />
            </com.google.android.material.textfield.TextInputLayout>

            <ImageView
                android:id="@+id/btnFilterDoctor"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_round_white"
                android:padding="10dp"
                android:src="@drawable/ic_filter"
                app:tint="#AB47BC" />

            <ImageView
                android:id="@+id/btnRefreshDoctor"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginStart="10dp"
                android:background="@drawable/bg_round_white"
                android:padding="10dp"
                android:src="@drawable/ic_refresh"
                app:tint="#80E9D4" />
        </LinearLayout>




        <!-- ⚡ QUICK ACTIONS -->
        <LinearLayout
            android:id="@+id/layoutActions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="18dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:background="@drawable/bg_quick_action"
            android:elevation="8dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="10dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnApprovedList"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Approved List"
                android:textStyle="bold"
                android:textColor="@color/white"
                app:backgroundTint="#AB47BC" />

            <View android:layout_width="12dp" android:layout_height="0dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnProfile"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Profile"
                android:textStyle="bold"
                android:textColor="@color/white"
                app:backgroundTint="#80E9D4" />

        </LinearLayout>




        <!-- 🩺 APPOINTMENTS LIST -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="10dp"
            app:cardBackgroundColor="@color/white">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvAppointments"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="12dp"
                    android:scrollbars="none"
                    tools:listitem="@layout/item_appointment" />

                <!-- EMPTY STATE -->
                <LinearLayout
                    android:id="@+id/emptyContainer"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:elevation="12dp">

                    <com.airbnb.lottie.LottieAnimationView
                        android:id="@+id/lottieEmpty"
                        android:layout_width="250dp"
                        android:layout_height="250dp"
                        android:visibility="visible"
                        app:lottie_rawRes="@raw/empty"
                        app:lottie_autoPlay="false"
                        app:lottie_loop="true" />

                    <TextView
                        android:id="@+id/tvEmptyMessage"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="No new appointments found"
                        android:textColor="#80E9D4"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:layout_marginTop="6dp"
                        android:gravity="center" />
                </LinearLayout>

            </FrameLayout>
        </androidx.cardview.widget.CardView>



        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_gravity="center"
            android:visibility="gone"
            android:indeterminateTint="#FFEB3B" />

    </LinearLayout>




    <!-- SIDE NAVIGATION DRAWER -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/doctorNavigationView"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        app:headerLayout="@layout/layout_doctor_drawer_header"
        app:menu="@menu/menu_doctor_drawer" />

</androidx.drawerlayout.widget.DrawerLayout>
