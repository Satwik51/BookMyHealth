<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="@drawable/bg_intro_curve">

    <!-- 🔹 Icon -->
    <ImageView
        android:id="@+id/ivIcon"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginBottom="24dp"
        android:src="@drawable/health"
        android:contentDescription="All in One Icon" />

    <!-- 🔹 Title -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="All in One App"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#80E9D4"
        android:layout_marginBottom="12dp" />

    <!-- 🔹 Description -->
    <TextView
        android:id="@+id/tvDescription"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Your complete healthcare companion — BookMyHealth connects you instantly to trusted doctors."
        android:textSize="14sp"
        android:textColor="@color/bgLight"
        android:gravity="center"
        android:paddingHorizontal="12dp" />
</LinearLayout>
