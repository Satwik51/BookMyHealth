<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:padding="24dp"
    android:background="@drawable/bg_dialog_round"
    android:orientation="vertical"
    android:gravity="center">

    <!-- Success Icon -->
    <ImageView
        android:id="@+id/successIcon"
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:src="@drawable/ic_success"
        android:layout_marginBottom="16dp" />

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Success!"
        android:textColor="#80E9D4"
        android:textStyle="bold"
        android:textSize="22sp"
        android:layout_marginBottom="8dp" />

    <!-- Message -->
    <TextView
        android:id="@+id/tvDialogMsg"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sign-up successful! Kindly update your profile in the Profile section for a better experience."
        android:textColor="#444"
        android:gravity="center"
        android:textSize="15sp"
        android:layout_marginBottom="20dp"
        android:paddingStart="10dp"
        android:paddingEnd="10dp" />

    <!-- Buttons Container -->
    <LinearLayout
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- OK Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDialogOk"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="OK"
            android:textColor="#FFFFFF"
            android:backgroundTint="#80E9D4"
            android:textAllCaps="false"
            android:padding="10dp"
            app:cornerRadius="12dp"
            android:layout_marginEnd="6dp" />

        <!-- Go to Profile Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGoProfile"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Go to Profile"
            android:textColor="#80E9D4"
            android:backgroundTint="#E0FFFA"
            android:textAllCaps="false"
            android:padding="10dp"
            app:cornerRadius="12dp"
            android:layout_marginStart="6dp" />

    </LinearLayout>

</LinearLayout>
