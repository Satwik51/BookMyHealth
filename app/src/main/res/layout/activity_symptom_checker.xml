<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <!-- BACKGROUND GRADIENT HEADER -->
    <View
        android:id="@+id/headerBackground"
        android:layout_width="match_parent"
        android:layout_height="280dp"
        android:background="@drawable/gradient_header"/>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="100dp">

            <!-- TOP HEADER SECTION -->
            <LinearLayout
                android:id="@+id/headerSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                app:layout_constraintTop_toTopOf="parent">

                <!-- TOP BAR WITH PROFILE -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvGreeting"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Good Morning!"
                            android:textColor="@color/white"
                            android:textSize="14sp"
                            android:alpha="0.9"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="AI Symptom Analyzer"
                            android:textColor="@color/white"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:layout_marginTop="4dp"/>

                    </LinearLayout>

                    <!-- PROFILE AVATAR -->
                    <FrameLayout
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:background="@drawable/circle_white_border">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_person"
                            app:tint="@color/white"/>

                    </FrameLayout>

                </LinearLayout>

                <!-- SUBTITLE -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Select your symptoms for AI-powered analysis"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:alpha="0.85"
                    android:layout_marginTop="8dp"/>

                <!-- STATS ROW -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="20dp">

                    <!-- ANALYZED COUNT -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="12dp"
                        android:background="@drawable/stat_chip_bg">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_analytics"
                            app:tint="@color/primary"/>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginStart="10dp">

                            <TextView
                                android:id="@+id/tvAnalysisCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="24"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="@color/primary_blue"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Analyzed"
                                android:textSize="11sp"
                                android:textColor="@color/white"/>

                        </LinearLayout>

                    </LinearLayout>

                    <View
                        android:layout_width="12dp"
                        android:layout_height="1dp"/>

                    <!-- ACCURACY -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="12dp"
                        android:background="@drawable/stat_chip_bg">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_verified"
                            app:tint="@color/accent_green"/>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginStart="10dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="98%"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="@color/primary_blue"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Accuracy"
                                android:textSize="11sp"
                                android:textColor="@color/white"/>

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

            <!-- MAIN CONTENT CARD -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/mainCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="200dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="@color/white"
                app:layout_constraintTop_toTopOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- CATEGORY CHIPS -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Categories"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary_blue"/>

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:scrollbars="none">

                        <com.google.android.material.chip.ChipGroup
                            android:id="@+id/chipGroupCategories"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:singleSelection="true"
                            app:selectionRequired="true">

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chipAll"
                                style="@style/Widget.Material3.Chip.Filter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="All"
                                app:chipIcon="@drawable/ic_apps"
                                app:chipBackgroundColor="@color/chip_bg_selector"
                                app:checkedIconVisible="false"/>

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chipGeneral"
                                style="@style/Widget.Material3.Chip.Filter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="General"
                                app:chipIcon="@drawable/ic_general"
                                app:chipBackgroundColor="@color/chip_bg_selector"/>

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chipPain"
                                style="@style/Widget.Material3.Chip.Filter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Pain"
                                app:chipIcon="@drawable/ic_pain"
                                app:chipBackgroundColor="@color/chip_bg_selector"/>

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chipDigestive"
                                style="@style/Widget.Material3.Chip.Filter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Digestive"
                                app:chipIcon="@drawable/ic_stomach"
                                app:chipBackgroundColor="@color/chip_bg_selector"/>

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chipRespiratory"
                                style="@style/Widget.Material3.Chip.Filter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Respiratory"
                                app:chipIcon="@drawable/ic_lungs"
                                app:chipBackgroundColor="@color/chip_bg_selector"/>

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chipSkin"
                                style="@style/Widget.Material3.Chip.Filter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Skin"
                                app:chipIcon="@drawable/ic_skin"
                                app:chipBackgroundColor="@color/chip_bg_selector"/>

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chipNeurological"
                                style="@style/Widget.Material3.Chip.Filter"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Neurological"
                                app:chipIcon="@drawable/ic_brain"
                                app:chipBackgroundColor="@color/chip_bg_selector"/>

                        </com.google.android.material.chip.ChipGroup>

                    </HorizontalScrollView>

                    <!-- SEARCH BAR -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/border_gray">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingHorizontal="16dp">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_search"
                                app:tint="@color/text_secondary"/>

                            <EditText
                                android:id="@+id/etSearch"
                                android:layout_width="0dp"
                                android:layout_height="52dp"
                                android:layout_weight="1"
                                android:background="@null"
                                android:hint="Search symptoms..."
                                android:textColorHint="@color/text_hint"
                                android:textSize="15sp"
                                android:paddingHorizontal="12dp"
                                android:inputType="text"
                                android:imeOptions="actionSearch"/>

                            <ImageView
                                android:id="@+id/btnVoice"
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:src="@drawable/ic_mic"
                                android:padding="8dp"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                app:tint="@color/primary_blue"/>

                            <ImageView
                                android:id="@+id/btnFilter"
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:src="@drawable/ic_filter"
                                android:padding="8dp"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                app:tint="@color/primary_blue"/>

                        </LinearLayout>

                    </com.google.android.material.card.MaterialCardView>

                    <!-- SELECTION PROGRESS -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="20dp"
                        android:gravity="center_vertical">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Selected Symptoms"
                                    android:textSize="14sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/primary_blue"/>

                                <View
                                    android:layout_width="8dp"
                                    android:layout_height="8dp"
                                    android:layout_marginStart="8dp"
                                    android:background="@drawable/circle_accent"/>

                            </LinearLayout>

                            <TextView
                                android:id="@+id/tvSelectedCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0 selected"
                                android:textSize="12sp"
                                android:textColor="@color/primary_blue"
                                android:layout_marginTop="2dp"/>

                        </LinearLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnClearAll"
                            style="@style/Widget.Material3.Button.TextButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Clear All"
                            android:textSize="12sp"
                            app:icon="@drawable/ic_close"
                            app:iconTint="@color/red"
                            android:textColor="@color/red"
                            app:iconSize="16dp"/>

                    </LinearLayout>

                    <!-- PROGRESS BAR -->
                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/progressBar"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        app:trackCornerRadius="4dp"
                        app:trackThickness="8dp"
                        app:indicatorColor="@color/primary_blue"
                        app:trackColor="@color/progress_bg"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- SYMPTOMS GRID -->
            <TextView
                android:id="@+id/tvSymptomsHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Common Symptoms"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/primary_blue"
                android:layout_marginStart="20dp"
                android:layout_marginTop="24dp"
                app:layout_constraintTop_toBottomOf="@id/mainCard"
                app:layout_constraintStart_toStartOf="parent"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvSymptoms"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:paddingHorizontal="12dp"
                android:nestedScrollingEnabled="false"
                android:clipToPadding="false"
                app:layout_constraintTop_toBottomOf="@id/tvSymptomsHeader"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- FLOATING ACTION BUTTON -->
    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fabAnalyze"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="24dp"
        android:text="Analyze Now"
        android:textColor="@color/white"
        app:iconTint="@color/white"
        app:backgroundTint="@color/primary_blue"
        app:elevation="8dp"
        app:fabSize="normal"/>

    <!-- RESULTS BOTTOM SHEET -->
    <LinearLayout
        android:id="@+id/bottomSheetResults"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bottom_sheet_bg"
        android:padding="24dp"
        app:layout_behavior="com.google.android.material.bottomsheet.BottomSheetBehavior"
        app:behavior_hideable="true"
        app:behavior_peekHeight="0dp">

        <!-- DRAG HANDLE -->
        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center"
            android:background="@drawable/drag_handle"
            android:layout_marginBottom="20dp"/>

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Analysis Results"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"/>

                <TextView
                    android:id="@+id/tvResultDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Based on 5 symptoms"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="2dp"/>

            </LinearLayout>

            <ImageView
                android:id="@+id/btnShare"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@drawable/ic_share"
                android:padding="10dp"
                android:background="@drawable/circle_light_gray"
                app:tint="@color/text_secondary"/>

        </LinearLayout>

        <!-- MATCHES LIST -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvResults"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:nestedScrollingEnabled="false"/>

        <!-- WARNING CARD (if needed) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardWarning"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:visibility="gone"
            app:cardCornerRadius="16dp"
            app:cardBackgroundColor="@color/warning_bg"
            app:strokeWidth="1dp"
            app:strokeColor="@color/warning">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_warning"
                    app:tint="@color/warning"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Consult a Doctor"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Some symptoms may require medical attention"
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="2dp"/>

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- ACTION BUTTONS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="20dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSaveResults"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="Save"
                app:icon="@drawable/ic_save"/>

            <View
                android:layout_width="12dp"
                android:layout_height="1dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCloseResults"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="2"
                android:text="Done"
                app:icon="@drawable/ic_check"/>

        </LinearLayout>

    </LinearLayout>

    <!-- LOADING OVERLAY -->
    <FrameLayout
        android:id="@+id/loadingOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC000000"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp"
            android:background="@drawable/glass_card">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Analyzing Symptoms..."
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginTop="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AI is processing your inputs"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="8dp"/>

            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/progressLoading"
                android:layout_width="200dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:trackCornerRadius="4dp"
                app:indicatorColor="@color/primary_blue"
                app:trackColor="@color/progress_bg"/>

        </LinearLayout>

    </FrameLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>