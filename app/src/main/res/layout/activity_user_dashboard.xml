<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.auth.user.UserDashboardActivity"
    android:fitsSystemWindows="true">

    <!-- ⭐ MAIN UI -->
    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:id="@+id/layoutUserDashboard"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FFFFFF">

        <!-- 🌈 Header BG -->
        <LinearLayout
            android:id="@+id/headerBackground"
            android:layout_width="match_parent"
            android:layout_height="350dp"
            android:background="@drawable/bg_intro_curve"
            android:orientation="horizontal" />

        <!-- 🧠 HEADER SECTION (Welcome upar hi rahega) -->
        <LinearLayout
            android:id="@+id/headerLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="10dp"
            android:elevation="4dp"
            android:layout_marginTop="10dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            >

           <ImageView
                android:id="@+id/ivProfile"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:src="@drawable/placeholder_profile"
                android:background="@drawable/bg_circle_white"
                android:padding="6dp"
                android:scaleType="centerCrop" />


            <LinearLayout
                android:orientation="vertical"
                android:layout_marginStart="12dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/tvWelcome"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Welcome User 👋"
                    android:textStyle="bold"
                    android:textSize="22sp"
                    android:textColor="@color/white"  />

                <TextView
                    android:id="@+id/tvSubTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Book your doctor appointment easily"
                    android:textSize="14sp"
                    android:textColor="@color/white" />
            </LinearLayout>
        </LinearLayout>

        <!-- ⭐⭐⭐ LOTTIE SLIDER -->
        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/userSlider"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginTop="130dp"
            android:clipToPadding="false"
            android:clipChildren="false"
            android:overScrollMode="never"
            android:paddingHorizontal="20dp" />

        <!-- ⭐ MAIN CONTENT -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="360dp"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- ⚡ QUICK ACTIONS -->
                <LinearLayout
                    android:id="@+id/layoutQuickActions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:weightSum="3"
                    android:layout_marginBottom="28dp">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardAppointments"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="4dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="6dp"
                        android:backgroundTint="@android:color/white">

                        <LinearLayout
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="12dp"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <ImageView
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:src="@drawable/ic_calender"
                                app:tint="#AB47BC" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Bookings"
                                android:textColor="#AB47BC"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:layout_marginTop="6dp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardGetSlip"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="4dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="6dp"
                        android:backgroundTint="@android:color/white">

                        <LinearLayout
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="12dp"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <ImageView
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:src="@drawable/ic_calender"
                                app:tint="@color/primary_blue" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="My Slip"
                                android:textColor="@color/primary_blue"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:layout_marginTop="6dp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardProfile"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="6dp"
                        android:backgroundTint="@android:color/white">

                        <LinearLayout
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="12dp"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <ImageView
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:src="@drawable/ic_doctor_placeholder"
                                app:tint="#80E9D4" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Profile"
                                android:textColor="#80E9D4"
                                android:textSize="12sp"
                                android:textStyle="bold"
                                android:layout_marginTop="6dp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

                <!-- 🎬 POSTER SLIDER (16:9) -->
                <androidx.viewpager2.widget.ViewPager2
                    android:id="@+id/posterSlider"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:layout_marginBottom="20dp"
                    android:clipToPadding="false"
                    android:clipChildren="false"
                    android:overScrollMode="never"/>

                <!-- 🔍 SEARCH + FILTER + REFRESH -->
                <LinearLayout
                    android:id="@+id/layoutSearchBar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="4dp"
                    android:layout_marginBottom="16dp">

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/searchLayout"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_search_curve"
                        android:layout_marginEnd="10dp"
                        android:padding="0dp"
                        app:boxBackgroundMode="none"
                        app:startIconDrawable="@drawable/ic_search1"
                        app:startIconTint="@color/black">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etSearch"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp"
                            android:paddingTop="8dp"
                            android:paddingBottom="8dp"
                            android:textSize="18sp"
                            android:gravity="center_vertical"
                            android:hint="Search doctor..."
                            android:textColor="#000"
                            android:background="@android:color/transparent" />

                    </com.google.android.material.textfield.TextInputLayout>


                    <!-- Filter Button -->
                    <ImageView
                        android:id="@+id/btnFilter"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_marginStart="10dp"
                        android:padding="10dp"
                        android:background="@drawable/bg_round_white"
                        android:src="@drawable/ic_filter"
                        app:tint="#AB47BC" />

                    <!-- Refresh Button -->
                    <ImageView
                        android:id="@+id/btnRefresh"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_marginStart="10dp"
                        android:padding="10dp"
                        android:background="@drawable/bg_round_white"
                        android:src="@drawable/ic_refresh"
                        app:tint="@color/primary_blue" />

                </LinearLayout>

                <!-- ⭐ Doctor Section Title -->
                <TextView
                    android:id="@+id/tvHeader"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Available Doctors 👨‍⚕️"
                    android:textSize="19sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary_blue"
                    android:layout_marginBottom="12dp" />

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:layout_marginHorizontal="16dp"
                    android:layout_marginBottom="2dp"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="8dp"
                    app:cardBackgroundColor="#FFFFFF">
                <!-- ⭐ Doctor List -->
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recyclerDoctors"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:scrollbars="none"
                        tools:listitem="@layout/item_doctor" />

                    <!-- EMPTY STATE -->
                    <LinearLayout
                        android:id="@+id/emptyContainer"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:visibility="gone"
                        android:elevation="20dp">

                        <com.airbnb.lottie.LottieAnimationView
                            android:id="@+id/lottieEmpty"
                            android:layout_width="220dp"
                            android:layout_height="220dp"
                            android:layout_marginBottom="8dp"
                            app:lottie_rawRes="@raw/empty"
                            app:lottie_autoPlay="true"
                            app:lottie_loop="true" />

                        <TextView
                            android:id="@+id/tvEmptyText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="No doctors available right now"
                            android:textColor="#80E9D4"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:gravity="center"/>
                    </LinearLayout>

                </FrameLayout>
                </androidx.cardview.widget.CardView>

                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:layout_gravity="center"
                    android:layout_marginTop="12dp"
                    android:indeterminateTint="#FFEB3B"
                    android:layout_marginBottom="12dp"
                    android:visibility="gone" />
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <!-- 🔥 FAB MENU OPTIONS -->
        <LinearLayout
            android:id="@+id/fabMenuLayout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_gravity="bottom|end"
            android:layout_marginBottom="90dp"
            android:layout_marginEnd="20dp"
            android:visibility="gone">

            <!-- OPTION 1 -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSymptomChecker"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AI Symptom Checker"
                android:layout_marginBottom="10dp"
                app:cornerRadius="20dp"
                android:backgroundTint="@color/purple_500"
                android:textColor="@android:color/white"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDrugSearch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Drug Info 💊"
                android:textAllCaps="false"
                android:layout_marginTop="8dp"
                android:backgroundTint="@color/primary_blue"
                android:textColor="@android:color/white"/>

            <!-- OPTION 3 -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnComingSoon2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AI CHAT BOT"
                app:cornerRadius="20dp"/>

        </LinearLayout>

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabSymptomChecker"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_margin="20dp"
            android:src="@drawable/ic_health"
            android:contentDescription="AI Symptom Checker"
            app:backgroundTint="@color/primary_blue"
            app:tint="@android:color/white"/>
    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <!-- ⭐ Navigation Drawer -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/sideNav"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        app:headerLayout="@layout/layout_drawer_header"
        app:menu="@menu/menu_drawer" />

</androidx.drawerlayout.widget.DrawerLayout>
