<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="22dp"
    app:cardElevation="10dp"
    app:strokeColor="#1FFFFFFF"
    app:strokeWidth="1dp"
    android:clickable="true"
    android:foreground="?attr/selectableItemBackgroundBorderless"
    app:cardBackgroundColor="@color/transparent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="@color/card"
        android:gravity="center_vertical">

        <!-- ⭐ Doctor Image -->
        <FrameLayout
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginEnd="16dp"
            android:background="@drawable/bg_doctor_photo_border"
            android:padding="3dp">

            <ImageView
                android:id="@+id/imgDoctor"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:clipToOutline="true"
                android:background="@drawable/bg_doctor_photo_shape"
                android:src="@drawable/ic_doctor_placeholder"/>
        </FrameLayout>


        <!-- ⭐ Doctor Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_vertical">

            <!-- Name -->
            <TextView
                android:id="@+id/tvDoctorName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dr. John Doe"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/primary_blue"
                android:layout_marginBottom="4dp" />

            <!-- Specialization -->
            <TextView
                android:id="@+id/tvSpecialization"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cardiologist"
                android:textSize="15sp"
                android:textColor="#FFEB3B"
                android:layout_marginBottom="3dp" />

            <!-- Experience -->
            <TextView
                android:id="@+id/tvExperience"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Experience: 5 yrs"
                android:textSize="13sp"
                android:textColor="#E65100"
                android:layout_marginBottom="4dp"/>


            <!-- ⭐ Clinic Name (Optional) -->
            <TextView
                android:id="@+id/tvClinicName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="City Health Clinic"
                android:textSize="14sp"
                android:textColor="#4A4A4A"
                android:visibility="gone"
                android:layout_marginBottom="4dp"/>

            <!-- ⭐ Availability (Optional) -->
            <TextView
                android:id="@+id/tvAvailability"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mon, Tue, Thu"
                android:textSize="13sp"
                android:textColor="#00796B"
                android:visibility="gone"
                android:layout_marginBottom="4dp"/>

            <!-- ⭐ Achievements (Optional) -->
            <TextView
                android:id="@+id/tvAchievements"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Awarded Best Cardiologist 2023"
                android:textSize="12sp"
                android:textColor="#5D4037"
                android:visibility="gone"
                android:maxLines="2"
                android:ellipsize="end"/>

            <!-- ⭐ Rating -->
            <LinearLayout
                android:id="@+id/layoutRating"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal"
                android:layout_marginTop="4dp">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_star"
                    app:tint="#FFC107" />

                <TextView
                    android:id="@+id/tvRating"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="4.8"
                    android:textSize="14sp"
                    android:textColor="#FF8F00"
                    android:layout_marginStart="4dp"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
